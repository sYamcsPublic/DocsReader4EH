{
  "name": "docs-reader-4eh-eh",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "simulator": "npx @evenrealities/evenhub-simulator \"http://localhost:5173/?simulator=true\"",
    "qr": "npx evenhub qr --http --port 5173",
    "qr:sim": "npx evenhub qr --http --port 5173 --path /?simulator=true",
    "build": "tsc -b && vite build",
    "pack": "npm run build && npx evenhub pack app.json dist -o DocsReader4EH.ehpk",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@evenrealities/even_hub_sdk": "^0.0.9",
    "@evenrealities/evenhub-cli": "^0.1.11",
    "@evenrealities/evenhub-simulator": "^0.6.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}